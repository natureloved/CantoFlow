module CantoFlow.Main.Test where

import CantoFlow.Main
import DA.Next.Set (fromList)
import Prelude
import DA.Test.Scenario (test, assertEq)

-- | CantoFlow Happy-Path Integration Test
-- |
-- | Step-by-step:
-- | 1. Supplier creates InvoiceRequest (signatories: supplier + buyer)
-- | 2. Supplier invites lenders
-- | 3. Buyer confirms invoice (separate BuyerConfirmation template)
-- | 4. Three lenders submit confidential FinancingBid contracts
-- |    -> LenderA sees only bidA, LenderB only bidB, etc.
-- | 5. Supplier accepts best bid (LenderB: lowest feeRate)
-- | 6. FundingAgreement created (supplier + lender + buyer signatories)
-- | 7. AuditAccessGrant + WorkflowEvents for the Auditor
-- | 8. Verify privacy model: supplier sees 3 bids, each lender sees 1
-- | 9. Record funding, schedule repayment, verify audit log

testHappyPath : Script ()
testHappyPath = test "CantoFlow happy path" $ do
  let supplier     = "Supplier"
      buyer        = "Buyer"
      lenderA      = "LenderA"
      lenderB      = "LenderB"
      lenderC      = "LenderC"
      auditor      = "Auditor"
      lenders      = fromList [lenderA, lenderB, lenderC]
      requestId    = "REQ-001"
      now          = time 2026 6 29 14 31 49

  --
  -- Step 1: Supplier creates InvoiceRequest
  -- Signatories: supplier + buyer
  -- Auditor is an optional observer (added later via AuditAccessGrant)
  --
  requestCid <- submit supplier do
    createCmd InvoiceRequest
      with requestId        = requestId
         supplier          = supplier
         buyer             = buyer
         invoiceId         = "INV-2026-001"
         amount            = 100000.0
         currency          = "USD"
         dueDate           = date 2026 9 1
         requestedAdvance  = 85000.0
         status            = Pending
         invitedLenders    = fromList []
         auditor           = auditor

  --
  -- Step 2: Supplier invites lenders to bid
  --
  submit supplier do
    exerciseCmd requestCid InviteLenders
      with lenders = lenders

  --
  -- Step 3: Buyer confirms invoice amount and due date
  -- BuyerConfirmation is a SEPARATE contract. Buyer does not see financing terms.
  --
  confirmCid <- submit supplier do
    createCmd BuyerConfirmation
      with confirmationId    = "CONF-001"
         invoiceRequestCid  = requestCid
         supplier           = supplier
         buyer              = buyer
         confirmedAmount    = 100000.0
         confirmedDueDate   = date 2026 9 1
         status             = Pending
         notes              = ""

  submit buyer do
    exerciseCmd confirmCid ConfirmInvoice

  confirmation <- query confirmCid
  assertEq "Confirmation status" confirmation.status Confirmed

  --
  -- Step 4: Three lenders submit confidential bids
  -- Canton privacy in action:
  --   Each FinancingBid is a SEPARATE Daml contract with signatories:
  --     {Supplier, LenderX}
  --   Supplier sees all 3 (signatory on each).
  --   LenderA sees ONLY bidA. LenderB sees ONLY bidB. LenderC sees ONLY bidC.
  --
  bidACid <- submit supplier do
    createCmd FinancingBid
      with bidId             = "BID-A"
         invoiceRequestCid  = requestCid
         supplier           = supplier
         lender             = lenderA
         offerAmount        = 85000.0
         feeRate            = 0.08
         expiry             = date 2026 11 29
         status             = Submitted

  bidBCid <- submit supplier do
    createCmd FinancingBid
      with bidId             = "BID-B"
         invoiceRequestCid  = requestCid
         supplier           = supplier
         lender             = lenderB
         offerAmount        = 90000.0
         feeRate            = 0.065
         expiry             = date 2026 9 14
         status             = Submitted

  bidCCid <- submit supplier do
    createCmd FinancingBid
      with bidId             = "BID-C"
         invoiceRequestCid  = requestCid
         supplier           = supplier
         lender             = lenderC
         offerAmount        = 88000.0
         feeRate            = 0.07
         expiry             = date 2026 10 15
         status             = Submitted

  --
  -- Step 5: Supplier accepts LenderB's bid (lowest feeRate: 6.5%, highest advance)
  --
  agreementCid <- submit supplier do
    exerciseCmd requestCid AcceptBid
      with bidCid = bidBCid

  --
  -- Step 6: Verify FundingAgreement
  -- Canton: supplier + lender + buyer are signatories, all see agreement.
  --
  agreement <- query agreementCid
  assertEq "Agreement status" agreement.status Active
  assertEq "Agreement lender" agreement.lender lenderB
  assertEq "Agreement principal" agreement.principal 90000.0

  --
  -- Step 7: Record funding and schedule repayment
  --
  submit supplier do
    exerciseCmd agreementCid RecordFunding

  submit supplier do
    exerciseCmd agreementCid ScheduleRepayment
      with amount = agreement.repaymentAmount

  --
  -- Step 8: Grant auditor access and log workflow events
  --
  grantCid <- submit supplier do
    createCmd AuditAccessGrant
      with grantId        = "GRANT-001"
         grantor          = supplier
         grantee          = auditor
         dealReference    = requestCid
         scope            = fromList ["InvoiceRequest", "FundingAgreement", "WorkflowEvent"]
         expiry           = date 2027 6 29
         status           = Active

  submit supplier do
    createCmd WorkflowEvent
      with eventId    = "EVT-001"
         eventType   = "InvoiceCreated"
         requestId   = requestId
         party       = supplier
         metadata    = "Invoice INV-2026-001 created for $100,000 USD"
         timestamp   = now

  submit buyer do
    createCmd WorkflowEvent
      with eventId    = "EVT-002"
         eventType   = "InvoiceConfirmed"
         requestId   = requestId
         party       = buyer
         metadata    = "Buyer confirmed amount and due date"
         timestamp   = now

  submit supplier do
    createCmd WorkflowEvent
      with eventId    = "EVT-003"
         eventType   = "BidsSubmitted"
         requestId   = requestId
         party       = supplier
         metadata    = "3 confidential bids received"
         timestamp   = now

  submit supplier do
    createCmd WorkflowEvent
      with eventId    = "EVT-004"
         eventType   = "BidAccepted"
         requestId   = requestId
         party       = supplier
         metadata    = "Accepted BID-B from LenderB at 6.5% fee rate"
         timestamp   = now

  --
  -- Step 9: Verify Canton privacy model
  --

  -- Supplier sees all 3 FinancingBid contracts (signatory on each)
  supplierBids <- queryFilter @FinancingBid (\b -> b.supplier == supplier)
  assertEq "Supplier should see 3 bids" (length supplierBids) 3

  -- LenderA sees only their own bid
  lenderABids <- queryFilter @FinancingBid (\b -> b.lender == lenderA)
  assertEq "LenderA should see only 1 bid" (length lenderABids) 1

  -- LenderB sees only their own bid
  lenderBBids <- queryFilter @FinancingBid (\b -> b.lender == lenderB)
  assertEq "LenderB should see only 1 bid" (length lenderBBids) 1

  -- LenderC sees only their own bid
  lenderCBids <- queryFilter @FinancingBid (\b -> b.lender == lenderC)
  assertEq "LenderC should see only 1 bid" (length lenderCBids) 1

  -- Auditor should see at least the invoice and agreement events
  auditorEvents <- queryFilter @WorkflowEvent (\e -> e.eventType == "InvoiceCreated" || e.eventType == "AgreementCreated")
  assertEq "Auditor should see key workflow events" (length auditorEvents) 2

  --
  -- Step 10: Mark agreement as repaid (end of happy path)
  --
  submit supplier do
    exerciseCmd agreementCid MarkRepaid
      with repaymentNote = "Full repayment on maturity date"

  repaidAgreement <- query agreementCid
  assertEq "Agreement should be Repaid" repaidAgreement.status Repaid

  return ()
